{
  "datasets": [
    {
      "name": "3f09bdf2",
      "displayName": "Hourly Temperature Data",
      "queryLines": [
        "SELECT\n",
        "  city_name,\n",
        "  hour_window,\n",
        "  avg_temp\n",
        "FROM\n",
        "  workspace.weather_gold.hourly\n",
        "ORDER BY\n",
        "  hour_window;"
      ]
    },
    {
      "name": "ca5fd35b",
      "displayName": "Current temperature bar chart",
      "config": {
        "version": "1.1",
        "source": "SELECT city_name, temperature_celsius, temp_category\r\nFROM workspace.weather_gold.snapshot\r\nORDER BY temperature_celsius DESC",
        "dimensions": [
          {
            "name": "city_name",
            "expr": "source.city_name",
            "displayName": "City Name"
          },
          {
            "name": "temperature_celsius",
            "expr": "source.temperature_celsius",
            "displayName": "Temperature Celsius"
          },
          {
            "name": "temp_category",
            "expr": "source.temp_category",
            "displayName": "Temp Category"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "02068aeb",
      "displayName": "Comfort level pie",
      "config": {
        "version": "1.1",
        "source": "SELECT comfort_level, COUNT(*) AS city_count\r\nFROM workspace.weather_gold.snapshot\r\nGROUP BY comfort_level",
        "dimensions": [
          {
            "name": "comfort_level",
            "expr": "source.comfort_level",
            "displayName": "Comfort Level"
          },
          {
            "name": "city_count",
            "expr": "source.city_count",
            "displayName": "City Count"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "2643075f",
      "displayName": "Live conditions table",
      "config": {
        "version": "1.1",
        "source": "SELECT\r\n  city_name,\r\n  ROUND(temperature_celsius, 1)  AS temp_c,\r\n  humidity_pct                   AS humidity,\r\n  wind_speed_mps                 AS wind_mps,\r\n  wind_direction_label           AS wind_dir,\r\n  weather_description,\r\n  comfort_level,\r\n  CASE WHEN is_daytime THEN 'Day' ELSE 'Night' END AS time_of_day\r\nFROM workspace.weather_gold.snapshot\r\nORDER BY temperature_celsius DESC",
        "dimensions": [
          {
            "name": "city_name",
            "expr": "source.city_name",
            "displayName": "City Name"
          },
          {
            "name": "temp_c",
            "expr": "source.temp_c",
            "displayName": "Temp C"
          },
          {
            "name": "humidity",
            "expr": "source.humidity",
            "displayName": "Humidity"
          },
          {
            "name": "wind_mps",
            "expr": "source.wind_mps",
            "displayName": "Wind Mps"
          },
          {
            "name": "wind_dir",
            "expr": "source.wind_dir",
            "displayName": "Wind Dir"
          },
          {
            "name": "weather_description",
            "expr": "source.weather_description",
            "displayName": "Weather Description"
          },
          {
            "name": "comfort_level",
            "expr": "source.comfort_level",
            "displayName": "Comfort Level"
          },
          {
            "name": "time_of_day",
            "expr": "source.time_of_day",
            "displayName": "Time Of Day"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "a7e826e2",
      "displayName": "Rainfall bar chart",
      "config": {
        "version": "1.1",
        "source": "SELECT city_name, SUM(total_rain_mm) AS total_rainfall_mm\r\nFROM workspace.weather_gold.hourly\r\nGROUP BY city_name\r\nORDER BY total_rainfall_mm DESC",
        "dimensions": [
          {
            "name": "city_name",
            "expr": "source.city_name",
            "displayName": "City Name"
          },
          {
            "name": "total_rainfall_mm",
            "expr": "source.total_rainfall_mm",
            "displayName": "Total Rainfall Mm"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    }
  ],
